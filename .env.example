# DevBoard environment variables — committed template.
# Copy to .env and adjust. After running infra/openfga/bootstrap.sh, fill in
# OPENFGA_STORE_ID + OPENFGA_MODEL_ID.

# Database
# Host port 5433 (mapped to container 5432) — host 5432 is often used by a local Postgres.
DATABASE_URL=postgresql+asyncpg://devboard:devboard@localhost:5433/devboard

# Redis
REDIS_URL=redis://localhost:6379

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=devboard
KEYCLOAK_CLIENT_ID=devboard-app

# OpenFGA
OPENFGA_API_URL=http://localhost:8082
# Set these after running: bash infra/openfga/bootstrap.sh
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=

# App
DEBUG=true
