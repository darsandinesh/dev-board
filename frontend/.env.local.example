# next-auth
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=generate-with: openssl rand -base64 32

# Keycloak (server-side OIDC)
KEYCLOAK_CLIENT_ID=devboard-app
KEYCLOAK_CLIENT_SECRET=devboard-secret
KEYCLOAK_ISSUER=http://localhost:8080/realms/devboard

# Backend API (browser-side)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public issuer (browser) for Keycloak federated logout
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8080/realms/devboard
